# JEIL AX 포털 — 환경변수 템플릿 (키 이름만, 값은 절대 커밋 금지 / CLAUDE.md §1)
# 실제 값은 .env(로컬) · Vercel 환경변수 · (운영) Azure Key Vault 에만 둔다.
# 복사: cp .env.example .env  후 값 채우기. .env 는 .gitignore 처리됨.

# ── Supabase (데모 데이터화) ─────────────────────────────
# 프로젝트: https://dvzohdqtjzocgcclgwro.supabase.co
SUPABASE_URL=
SUPABASE_ANON_KEY=              # publishable(anon) — 프론트 노출 가능(RLS 전제)
SUPABASE_SERVICE_ROLE_KEY=     # 관리 키 — 서버 전용, 절대 프론트/Git 금지

# ── Microsoft Entra ID (사내 SSO) ───────────────────────
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=           # 서버 전용 · 시크릿 매니저 (만료 2026-12-09)

# ── (운영/Azure 단계) ERP 중간 DB ───────────────────────
ERP_DB_CONN=                   # 읽기 전용 중간 DB 접속 문자열 — 서버 전용
