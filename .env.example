# JEIL AX 포털 — 환경변수 템플릿 (키 이름만, 값은 절대 커밋 금지 / CLAUDE.md §1)
# 실제 값은 .env(로컬) · Vercel 환경변수 · (운영) Azure Key Vault 에만 둔다.
# 복사: cp .env.example .env  후 값 채우기. .env 는 .gitignore 처리됨.

# ── Supabase (데모 데이터화) ─────────────────────────────
# 프로젝트: https://dvzohdqtjzocgcclgwro.supabase.co
SUPABASE_URL=
SUPABASE_ANON_KEY=              # publishable(anon) — 프론트 노출 가능(RLS 전제)
SUPABASE_SERVICE_ROLE_KEY=     # 관리 키 — 서버 전용, 절대 프론트/Git 금지

# ── Microsoft Entra ID (사내 SSO) ───────────────────────
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=           # 서버 전용 · 시크릿 매니저 (만료 2026-12-09)

# ── AI 챗봇 게이트웨이 (Supabase Edge Function: jeil-chat) ──
# 값은 Supabase 대시보드 → Edge Functions → Secrets 에만 등록 (프론트/Git 금지)
OPENAI_API_KEY=                # OpenAI API 키 — 서버(Edge Function) 전용
OPENAI_MODEL=                  # 선택. 미설정 시 gpt-4o-mini

# ── ERP 중간 DB ETL (10_ERP_DB연계/etl/) ────────────────
ERP_DB_CONN=                   # ERP(UNIERP MSSQL) 읽기 전용 pyodbc 접속 문자열 — 서버 배포 시에만 입력. 관리자 PC에서는 비워두면 %USERPROFILE%\.erp\ DPAPI 저장소 폴백(etl/_erp_conn.py) 사용. 평문 비밀번호를 이 파일·.env에 넣지 말 것
ERP_DB_META_DIR=               # 선택. ERP 테이블 사전 메타 폴더(기본: 사내 OneDrive ERP_DB/erp_chat/data)
